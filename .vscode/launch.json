{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run RyzOS Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server.js",
      "console": "integratedTerminal",
      "restart": true,
      "env": {
        "PORT": "8080"
      },
      "serverReadyAction": {
        "pattern": "Server running at (https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Debug RyzOS Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server.js",
      "console": "integratedTerminal",
      "restart": true,
      "env": {
        "PORT": "8080"
      },
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "pattern": "Server running at (https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}